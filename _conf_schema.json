{
  "limits": {
    "description": "基础限制设置",
    "type": "object",
    "items": {
      "default_daily_limit": {
        "description": "默认每日调用限制（每个用户/群组每天的默认调用次数）",
        "type": "int",
        "default": 20
      },
      "default_weekly_limit": {
        "description": "默认每周调用限制（0 表示不启用周限制）",
        "type": "int",
        "default": 0
      },
      "default_monthly_limit": {
        "description": "默认每月调用限制（0 表示不启用月限制）",
        "type": "int",
        "default": 0
      },
      "daily_reset_time": {
        "description": "每日重置时间（HH:MM 格式）",
        "type": "string",
        "default": "00:00"
      },
      "weekly_reset_day": {
        "description": "每周重置日（1=周一, 7=周日）",
        "type": "int",
        "default": 1
      },
      "monthly_reset_day": {
        "description": "每月重置日（1-28，超出月尾取最后一天）",
        "type": "int",
        "default": 1
      },
      "exempt_users": {
        "description": "豁免用户ID列表（不受任何限制）",
        "type": "list",
        "default": [],
        "items": {
          "type": "string"
        }
      },
      "priority_users": {
        "description": "优先用户ID列表（不参与群组共享限制）",
        "type": "list",
        "default": [],
        "items": {
          "type": "string"
        }
      },
      "group_mode_settings": {
        "description": "群组模式设置（格式：群ID:shared 或 群ID:individual）",
        "type": "text",
        "default": "",
        "hint": "一行一个，例如：\n123456:shared\n789012:individual"
      },
      "user_limits": {
        "description": "用户特定限制（格式：用户ID:次数）",
        "type": "text",
        "default": "",
        "hint": "一行一个，例如：\n123456789:100\n987654321:50"
      },
      "group_limits": {
        "description": "群组特定限制（格式：群ID:次数）",
        "type": "text",
        "default": "",
        "hint": "一行一个，例如：\n123456:50\n789012:30"
      },
      "time_period_limits": {
        "description": "时间段限制（格式：HH:MM-HH:MM:次数[:enabled]）",
        "type": "text",
        "default": "",
        "hint": "一行一个，例如：\n09:00-12:00:5:true\n14:00-18:00:10:true"
      },
      "skip_patterns": {
        "description": "忽略处理的消息前缀",
        "type": "list",
        "default": ["#", "*"],
        "items": {
          "type": "string"
        }
      },
      "enabled_limit_types": {
        "description": "启用的限制类型（至少选一项）",
        "type": "list",
        "default": ["daily"],
        "items": {
          "type": "string"
        }
      }
    }
  },
  "messages": {
    "description": "消息设置",
    "type": "object",
    "items": {
      "show_remaining_count": {
        "description": "是否在达到限制时显示剩余次数",
        "type": "bool",
        "default": true
      },
      "usage_tip": {
        "description": "使用提示消息（支持占位符：{usage}, {limit}, {remaining}, {limit_type}）",
        "type": "text",
        "default": "您今日的 LLM 调用次数已用完（{usage}/{limit}）。请在 {reset_time} 后重试。"
      }
    }
  }
}
